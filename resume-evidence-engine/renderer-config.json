{
  "version": "2026-05-17.1",
  "purpose": "Default settings for the flat Markdown-to-DOCX renderer used by both ChatGPT Projects and Codex.",
  "paths": {
    "template": "reference.docx",
    "default_output_dir": "outputs",
    "qa_report": "auto",
    "download_dir": "",
    "cache_file": "outputs/render-validation-cache.json"
  },
  "render_defaults": {
    "mode": "fast",
    "density": "auto",
    "cache_validation": true,
    "force_visual_qa": false,
    "preserve_intermediates": false,
    "validate_output": true,
    "max_pages_resume": null,
    "max_pages_cover_letter": null
  },
  "document_rules": {
    "infer_document_type": true,
    "standalone_page_targets": false,
    "multi_resume_delivery": "zip",
    "single_document_download_copy": true,
    "download_filename_style": "ascii-hyphenated",
    "human_resume_filename": "Candidate Name - Resume - Company, Abbrev Role.docx",
    "human_cover_letter_filename": "Candidate Name - Cover Letter - Company, Abbrev Role.docx"
  },
  "office_environment": {
    "installed_office": "Microsoft Office / Word",
    "visual_qa_renderer": "Microsoft Word automation when Codex parent workflows require page images",
    "libreoffice_available": false,
    "soffice_available": false
  },
  "style_profiles": {
    "normal": {
      "resume_font": 9.0,
      "resume_name_font": 18.0,
      "resume_section_font": 12.0,
      "cover_font": 12.0,
      "section_gap_lines": 1.5,
      "section_after": 3,
      "role_before": 4,
      "experience_role_gap_lines": 1.15,
      "body_after": 2,
      "bullet_after": 1,
      "resume_margin": 0.25,
      "cover_margin": 0.85
    },
    "compact": {
      "resume_font": 9.0,
      "resume_name_font": 17.0,
      "resume_section_font": 12.0,
      "cover_font": 11.5,
      "section_gap_lines": 1.3,
      "section_after": 2,
      "role_before": 3,
      "experience_role_gap_lines": 1.08,
      "body_after": 1,
      "bullet_after": 0,
      "resume_margin": 0.26,
      "cover_margin": 0.78
    },
    "tight": {
      "resume_font": 8.7,
      "resume_name_font": 16.0,
      "resume_section_font": 10.8,
      "cover_font": 11.0,
      "section_gap_lines": 1.15,
      "section_after": 1,
      "role_before": 2,
      "experience_role_gap_lines": 1.0,
      "body_after": 0,
      "bullet_after": 0,
      "resume_margin": 0.25,
      "cover_margin": 0.75
    }
  },
  "margin_adjustments": {
    "horizontal_margin_increase": 0.375,
    "vertical_margin_increase": 0.25
  },
  "validation_rules": {
    "reject_literal_markdown_bullets": true,
    "reject_raw_urls_except_visible_urls": true,
    "reject_resume_tables_columns_textboxes_images_drawings": true,
    "require_expected_hyperlinks": true,
    "write_qa_report": true,
    "allowed_resume_review_spans": [
      {
        "attribute": "data-change",
        "value": "customized",
        "color": "C00000",
        "meaning": "Changed resume review text renders red."
      },
      {
        "attribute": "data-origin",
        "value": "job-description-keyword",
        "color": "008000",
        "meaning": "JD-origin strategic keyword review text renders green."
      }
    ]
  },
  "performance": {
    "routine_mode": "fast",
    "fast_mode_behavior": "Skip page-image rendering and perform structural DOCX validation.",
    "qa_mode_behavior": "Use only when page count or visual inspection is required.",
    "cache_visual_qa_fingerprints": true
  }
}
